# Silent Butler — Docker Compose Environment Variables
# Copy this file to .env in the merged/ directory and adjust as needed

# PostgreSQL password for the silentbutler user
DB_PASSWORD=silentbutler

# JWT secret key (change in production!)
JWT_SECRET=my_super_secret_token_platon_123_413_555_000

# JWT expiration in milliseconds (default: 24 hours)
JWT_EXPIRATION=86400000
